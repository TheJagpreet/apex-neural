{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File ./.github/scripts/hooks/pre-tool-guard.ps1",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File ./.github/scripts/hooks/post-edit-lint.ps1",
        "timeout": 30
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File ./.github/scripts/hooks/session-init.ps1",
        "timeout": 30
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File ./.github/scripts/hooks/subagent-tracker.ps1",
        "timeout": 5
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File ./.github/scripts/hooks/subagent-tracker.ps1",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "powershell -ExecutionPolicy Bypass -File ./.github/scripts/hooks/phase-gate.ps1",
        "timeout": 10
      }
    ]
  }
}
