{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extensions/apex-neural-memory"
      ],
      "outFiles": [
        "${workspaceFolder}/extensions/apex-neural-memory/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile - extensions/apex-neural-memory"
    }
  ]
}
